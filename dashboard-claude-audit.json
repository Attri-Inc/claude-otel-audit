  "layout": [
    { "i": "cost-per-dev", "x": 0, "y": 0, "w": 6, "h": 3 },
    { "i": "tokens-per-dev", "x": 6, "y": 0, "w": 6, "h": 3 },
    { "i": "sessions-per-dev", "x": 0, "y": 3, "w": 6, "h": 3 },
    { "i": "active-time-per-dev", "x": 6, "y": 3, "w": 6, "h": 3 },
    { "i": "loc-per-dev", "x": 0, "y": 6, "w": 4, "h": 3 },
    { "i": "commits-per-dev", "x": 4, "y": 6, "w": 4, "h": 3 },
    { "i": "prs-per-dev", "x": 8, "y": 6, "w": 4, "h": 3 },
    { "i": "cost-by-plan", "x": 0, "y": 9, "w": 4, "h": 3 },
    { "i": "cost-by-team", "x": 4, "y": 9, "w": 4, "h": 3 },
    { "i": "cost-by-model", "x": 8, "y": 9, "w": 4, "h": 3 },
    { "i": "tokens-by-type", "x": 0, "y": 12, "w": 6, "h": 3 },
    { "i": "edit-decisions", "x": 6, "y": 12, "w": 6, "h": 3 }
  ],
  "widgets": [
    {
      "id": "cost-per-dev",
      "title": "Cost per Developer (USD)",
      "description": "Total Claude Code cost grouped by developer",
      "panelTypes": "bar",
      "query": {
        "queryType": "builder",
        "builder": {
          "queryData": [
            {
              "dataSource": "metrics",
              "queryName": "A",
              "aggregateOperator": "sum",
              "aggregateAttribute": {
                "key": "claude_code.cost.usage",
                "type": "Sum",
                "dataType": "float64",
                "isMonotonic": true
              },
              "groupBy": [
                {
                  "key": "developer.name",
                  "dataType": "string",
                  "type": "resource",
                  "isColumn": false
                }
              ],
              "expression": "A",
              "disabled": false,
              "timeAggregation": "sum",
              "spaceAggregation": "sum"
            }
          ],
          "queryFormulas": []
        }
      },
      "softMin": 0
    },
