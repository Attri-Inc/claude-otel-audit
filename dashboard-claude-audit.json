  "variables": {
    "developer": {
      "type": "QUERY",
      "name": "developer",
      "description": "Filter by developer name",
      "queryValue": "SELECT DISTINCT JSONExtractString(resources_string, 'developer.name') as developer FROM signoz_metrics.distributed_samples_v4 WHERE metric_name = 'claude_code.session.count' AND developer != '' ORDER BY developer",
      "customValue": "",
      "multiSelect": true,
      "showALLOption": true,
      "sort": "ASC",
      "selectedValue": "ALL"
    },
    "team": {
      "type": "QUERY",
      "name": "team",
      "description": "Filter by team",
      "queryValue": "SELECT DISTINCT JSONExtractString(resources_string, 'team.id') as team FROM signoz_metrics.distributed_samples_v4 WHERE metric_name = 'claude_code.session.count' AND team != '' ORDER BY team",
      "customValue": "",
